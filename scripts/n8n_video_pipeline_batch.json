    {
      "parameters": {
        "method": "POST",
        "url": "http://127.0.0.1:8001/process-video",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "youtube_id",
              "value": "={{ $json.youtube_video_id }}"
            },
            {
              "name": "lesson_id",
              "value": "={{ $json.id }}"
            }
          ]
        },
        "options": {
