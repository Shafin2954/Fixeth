          },
          "timeout": 600000
        }
      },
      "id": "f5869cb8-57d3-47c3-bb03-6c4ef5e0be10",
      "name": "Call Python Server (Download + Whisper)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        -2880,
        -560
      ],
      "continueOnFail": true
    },
    {
      "parameters": {
        "jsCode": "const segments  = items[0].json.segments || [];\nconst lessonId  = items[0].json.lesson_id;\nconst youtubeId = items[0].json.youtube_id;\nconst title     = items[0].json.title || 'Unknown';\n\nif (!segments.length) {\n  throw new Error(`No segments for lesson ${lessonId}`);\n}\n\nconst TARGET_WORDS = 150;\nconst chunks = [];\nlet buffer = [], wordCount = 0, chunkStart = segments[0].start;\n\nfor (let i = 0; i < segments.length; i++) {\n  const seg = segments[i];\n  buffer.push(seg);\n  wordCount += seg.text.trim().split(/\\s+/).length;\n  const isLast = i === segments.length - 1;\n\n  if (wordCount >= TARGET_WORDS || isLast) {\n    const chunkText = buffer.map(s => s.text.trim()).join(' ').trim();\n    const chunkEnd  = buffer[buffer.length - 1].end;\n    if (chunkText.length > 0) {\n      chunks.push({\n        json: {\n          lesson_id:  lessonId,\n          youtube_id: youtubeId,\n          title:      title,\n          chunk_text: chunkText,\n          start_time: Math.round(chunkStart * 1000) / 1000,\n          end_time:   Math.round(chunkEnd   * 1000) / 1000,\n          chunk_index: chunks.length\n        }\n      });\n    }\n    buffer = []; wordCount = 0;\n    if (!isLast) chunkStart = segments[i + 1].start;\n  }\n}\n\nreturn chunks;"
      },
      "id": "fabd36c3-988e-481e-a44a-7def0f92bd9c",
      "name": "Chunk Segments (~150 words each)",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -2352,
        -752
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://localhost:11434/api/embeddings",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "model",
              "value": "nomic-embed-text"
            },
            {
              "name": "prompt",
              "value": "={{ $json.chunk_text }}"
            }
          ]
        },
        "options": {
