            }
          },
          "timeout": 60000
        }
      },
      "id": "625b9c10-55df-4571-ac66-89bb9c092053",
      "name": "Get Embedding (Ollama)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        -2224,
        -896
      ]
    },
    {
      "parameters": {
        "jsCode": "const embedding = items[0].json.embedding;\n\nif (!embedding || !Array.isArray(embedding)) {\n  throw new Error('Ollama returned no embedding');\n}\nif (embedding.length !== 768) {\n  throw new Error(`Expected 768-dim, got ${embedding.length}`);\n}\n\nconst chunk = $('Chunk Segments (~150 words each)').first().json;\n\nreturn [{\n  json: {\n    lesson_id:  chunk.lesson_id,\n    chunk_text: chunk.chunk_text,\n    start_time: chunk.start_time,\n    end_time:   chunk.end_time,\n    embedding:  embedding\n  }\n}];"
      },
      "id": "3e886946-a15d-4118-91ba-a8f9befa049c",
      "name": "Attach Embedding to Chunk",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -2112,
        -1024
      ]
    },
    {
      "parameters": {
        "jsCode": "const chunk = items[0].json;\nreturn [{\n  json: {\n    status:    'chunk_inserted',\n    lesson_id: chunk.lesson_id\n  }\n}];"
      },
      "id": "2ff62f28-850e-4229-8dcb-221eed984ef9",
      "name": "Log Chunk Inserted",
